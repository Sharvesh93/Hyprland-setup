{
  "positionX": "center",
  "positionY": "top",
  "layer": "overlay",
  "layer-shell": true,


  "cssPriority": "user",

  "control-center-width": 420,
  "control-center-height": 700,

  "notification-window-width": 420,
  "notification-icon-size": 56,
  "notification-body-image-height": 180,
  "notification-body-image-width": 360,

  "fit-to-screen":false,
  "timeout": 5,
  "keyboard-shortcuts": true,

  "widgets": [
    "title",
    "dnd",
    "notifications"
  ],

  "widget-config": {
    "title": {
      "text": "Notifications",
      "clear-all-button": true
    },

    "dnd": {
      "text": "Do Not Disturb"
    }
  }
}